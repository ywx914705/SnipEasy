<Application x:Class="SnipEasy.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="LineBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="TextBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="CaretBrush" Value="#0F172A" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3,0,6" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
    </Application.Resources>
</Application>
