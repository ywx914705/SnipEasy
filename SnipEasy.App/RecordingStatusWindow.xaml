<Window x:Class="SnipEasy.App.RecordingStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnipEasy 录屏状态"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Opacity="0"
        SourceInitialized="RecordingStatusWindow_SourceInitialized"
        Loaded="RecordingStatusWindow_Loaded"
        Closed="RecordingStatusWindow_Closed">
    <Window.Resources>
        <!-- 高级缓动函数 -->
        <CubicEase x:Key="SmoothEase" EasingMode="EaseInOut" />
        <SineEase x:Key="SineEase" EasingMode="EaseInOut" />

        <!-- Logo 呼吸动画 - 微妙的缩放 -->
        <Storyboard x:Key="LogoBreath">
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.08"
                             Duration="0:0:2.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.08"
                             Duration="0:0:2.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
        </Storyboard>

        <!-- Logo 光晕呼吸 -->
        <Storyboard x:Key="LogoGlowBreath">
            <DoubleAnimation Storyboard.TargetName="LogoGlowOuter"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.3"
                             Duration="0:0:2.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
            <DoubleAnimation Storyboard.TargetName="LogoGlowOuter"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.5"
                             Duration="0:0:2.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
            <DoubleAnimation Storyboard.TargetName="LogoGlowOuter"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.5"
                             Duration="0:0:2.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
        </Storyboard>

        <!-- 录制指示灯脉冲 -->
        <Storyboard x:Key="RecordDotPulse">
            <DoubleAnimation Storyboard.TargetName="RecordDotScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.2"
                             Duration="0:0:1.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
            <DoubleAnimation Storyboard.TargetName="RecordDotScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.2"
                             Duration="0:0:1.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
            <DoubleAnimation Storyboard.TargetName="RecordDotGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.2" To="0.5"
                             Duration="0:0:1.5"
                             RepeatBehavior="Forever"
                             AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}" />
        </Storyboard>

        <!-- 秒数跳动 -->
        <Storyboard x:Key="SecondTick">
            <DoubleAnimation Storyboard.TargetName="SecondTextScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.15" To="1"
                             Duration="0:0:0.4"
                             EasingFunction="{StaticResource SmoothEase}" />
            <DoubleAnimation Storyboard.TargetName="SecondTextScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.15" To="1"
                             Duration="0:0:0.4"
                             EasingFunction="{StaticResource SmoothEase}" />
        </Storyboard>

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="40"
                          ShadowDepth="12"
                          Direction="270"
                          Opacity="0.15"
                          Color="#0F172A" />

        <Style x:Key="RecordingActionButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.04" ScaleY="1.04" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonChrome" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonChrome" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LogoBreath}" />
            <BeginStoryboard Storyboard="{StaticResource LogoGlowBreath}" />
            <BeginStoryboard Storyboard="{StaticResource RecordDotPulse}" />
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="Chrome"
            Margin="10"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="16"
            Effect="{StaticResource CardShadow}"
            MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
        <Grid Margin="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo + 录制指示 + 时间 -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <!-- Logo -->
                <Grid Width="48" Height="48" Margin="0,0,18,0"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>

                    <!-- 外层光晕 -->
                    <Ellipse x:Name="LogoGlowOuter"
                             Fill="#3B82F6"
                             Opacity="0"
                             Width="48"
                             Height="48"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- 内层背景 -->
                    <Ellipse Fill="#EFF6FF"
                             Width="48"
                             Height="48" />

                    <!-- Logo 图片 -->
                    <Image Source="Assets/SnipEasyMark.png"
                           Width="32"
                           Height="32"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Grid>

                <!-- 录制指示灯 -->
                <Grid Width="12" Height="12" Margin="0,0,16,0"
                      RenderTransformOrigin="0.5,0.5">
                    <Ellipse x:Name="RecordDotGlow"
                             Fill="#EF4444"
                             Opacity="0.2"
                             Width="12"
                             Height="12" />
                    <Ellipse x:Name="RecordDot"
                             Fill="#EF4444"
                             Width="8"
                             Height="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="RecordDotScale" ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>

                <!-- 时间 -->
                <TextBlock x:Name="ElapsedText"
                           Text="00:00"
                           FontSize="20"
                           FontWeight="SemiBold"
                           FontFamily="Consolas, Segoe UI"
                           Foreground="#0F172A"
                           VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform x:Name="SecondTextScale" ScaleX="1" ScaleY="1" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

            <!-- 分隔线 -->
            <Rectangle Grid.Column="1"
                       Width="1"
                       Height="32"
                       Fill="#E2E8F0"
                       VerticalAlignment="Center" />

            <!-- 状态文字 -->
            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        Margin="0,2,0,0">
                <TextBlock x:Name="StatusText"
                           Text="录制中"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#0F172A" />
                <TextBlock x:Name="RouteText"
                           Text=""
                           FontSize="12"
                           Foreground="#64748B"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="180" />
            </StackPanel>

            <!-- 分隔线 -->
            <Rectangle Grid.Column="3"
                       Width="1"
                       Height="32"
                       Fill="#E2E8F0"
                       VerticalAlignment="Center" />

            <!-- 提示文字 -->
            <TextBlock x:Name="ActionHintText"
                       Grid.Column="4"
                       Text="F2 停止"
                       FontSize="12"
                       Foreground="#94A3B8"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />

            <!-- 操作按钮 -->
            <StackPanel Grid.Column="5"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="StopButton"
                        Style="{StaticResource RecordingActionButton}"
                        Background="#EF4444"
                        Foreground="#FFFFFF"
                        Click="StopButton_Click"
                        ToolTip="停止录屏">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Width="8" Height="8" Background="White" CornerRadius="4" Margin="0,0,8,0" />
                        <TextBlock x:Name="StopButtonLabel"
                                   Text="停止"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel x:Name="DecisionPanel"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource RecordingActionButton}"
                            Background="#F8FAFC"
                            Foreground="#334155"
                            Click="CancelButton_Click"
                            ToolTip="删除本次录屏"
                            Margin="0,0,8,0">
                        <TextBlock Text="取消" />
                    </Button>
                    <Button x:Name="SaveButton"
                            Style="{StaticResource RecordingActionButton}"
                            Background="#2563EB"
                            Foreground="#FFFFFF"
                            Click="SaveButton_Click"
                            ToolTip="保存本次录屏">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="保存" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
